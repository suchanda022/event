{
  "compilerOptions": {
    "rootDir": "./src",

    "outDir": "./dist",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "target": "ES2020",

    "strict": true,

    "esModuleInterop": true,

    "experimentalDecorators": true,

    "emitDecoratorMetadata": true,

    "skipLibCheck": true
  },

  "include": ["src"]
}